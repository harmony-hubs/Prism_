# PRISM (Vite) — copy to `.env` and uncomment what you need.
#
# Ika (required reading for integrators):
#   https://solana-pre-alpha.ika.xyz/print.html
# Encrypt:
#   https://docs.encrypt.xyz/
#
# deploy `program/` first, then set VITE_PRISM_PROGRAM_ID to YOUR controller id
# (not the Ika dWallet program id below).

# Solana JSON-RPC (default: devnet)
# VITE_SOLANA_RPC=https://api.devnet.solana.com

# Sui JSON-RPC (default: devnet)
# VITE_SUI_RPC=https://fullnode.devnet.sui.io

# Ika pre-alpha gRPC (book: Installation → Pre-Alpha Environment)
# VITE_IKA_GRPC=https://pre-alpha-dev-1.ika.ika-network.net:443

# Ika dWallet program on devnet (MessageApproval / approve_message)
# VITE_IKA_DWALLET_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY

# After you deploy program/ (your PRISM controller — NOT the Ika program id above)
# VITE_PRISM_PROGRAM_ID=
